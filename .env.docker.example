##############################################################################
# BMAC Docker Environment Configuration
#
# Copy this file to .env before running docker compose.
# Values below are set for a Docker-based deployment.
##############################################################################

APP_NAME=BMAC
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Error tracking (optional)
BUGSNAG_API_KEY=
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — hostnames match docker-compose service names
# For MariaDB / MySQL:
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=bmac
DB_USERNAME=bmac
DB_PASSWORD=change-me-to-a-secure-password
DB_TABLE_PREFIX=
DB_LOWER_STRING_LENGTH=false

# For PostgreSQL, change to:
# DB_CONNECTION=pgsql
# DB_PORT=5432

BROADCAST_CONNECTION=log

# Use Redis for cache, sessions, and queues in Docker
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local

# Redis — hostname matches docker-compose service name
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — configure for your mail provider
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (optional, for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OAuth / VATSIM Connect
OAUTH_BASE=https://auth.vatsim.net
OAUTH_CLIENT=
OAUTH_SECRET=
OAUTH_SCOPES="full_name,email"

# OAuth variable mapping (leave as-is for VATSIM Connect)
OAUTH_MAPPING_CID=data-cid
OAUTH_MAPPING_FIRSTNAME=data-personal-name_first
OAUTH_MAPPING_LASTNAME=data-personal-name_last
OAUTH_MAPPING_EMAIL=data-personal-email

# Branding
SITE_TITLE="Booking"
SITE_DIVISION="Division Name"
SITE_DIVISION_URL="https://division.org"
SITE_CONTACT_MAIL="event@division.org"
SITE_PILOTBRIEF_URL="https://www.division.org/visiting-pilots/"
SITE_CHARTS_URL="https://www.division.org/charts/"

# Bootstrap colors — these are baked into CSS at Docker build time.
# To customize, rebuild the image with --build-arg flags:
#   docker compose -f docker-compose.prod.yml build \
#     --build-arg BOOTSTRAP_COLOR_PRIMARY="#FF0000"
BOOTSTRAP_COLOR_PRIMARY="#2C3E50"
BOOTSTRAP_COLOR_SECONDARY="#95a5a6"
BOOTSTRAP_COLOR_TERTIARY="#18BC9C"
BOOTSTRAP_COLOR_SUCCESS="#18BC9C"
BOOTSTRAP_COLOR_DANGER="#E74C3C"
BOOTSTRAP_COLOR_WARNING="#F39C12"

ACTIVITY_LOGGER_ENABLED=true
TELESCOPE_ENABLED=false
